# Copy to .env.local and replace every placeholder before running the app.
APP_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/gaila

# Replace with a secure random secret of at least 32 characters (required in production).
SESSION_SECRET=GENERATE_32_PLUS_RANDOM_CHARS_HERE

ADMIN_EMAIL=admin@gaila.ae
# Set a strong password before seeding or creating the admin user.
ADMIN_PASSWORD=REPLACE_ME_STRONG_PASSWORD
ADMIN_NAME=Gaila Admin

# Optional: distributed lead rate limiting (recommended in production).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Only enable when your reverse proxy strips untrusted X-Forwarded-For values.
# TRUST_PROXY_HEADERS=false
